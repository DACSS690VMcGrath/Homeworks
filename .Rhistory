# clean memory ------------------------------------------------------------
rm(list = ls())
#Do not read file locally - copy from github
filename="https://github.com/DACSS690VMcGrath/hw-test/raw/main/theFile.csv"
mydata=read.csv(filename)
# see data ----------------------------------------------------------
head(mydata)
# see data types ----------------------------------------------------------
str(mydata)
# deliverable 1 ----------------------------------------------------------
library(ggplot2)
base= ggplot(data=mydata)
del1Draft= base + geom_bar(aes(x=LocaleType))
del1Draft
# save del1Draft ----------------------------------------------------------
saveRDS(del1Draft, file = "del1Draft.rds")
del2Draft= base + geom_histogram(aes(x=Student.Teacher.Ratio))
del2Draft
# save del2Draft ----------------------------------------------------------
saveRDS(del2Draft, file = "del2Draft.rds")
del3Draft= base + geom_point(aes(x=Student.Teacher.Ratio,
y=Free.Lunch))
del3Draft
# save del3Draft ----------------------------------------------------------
saveRDS(del3Draft, file = "del3Draft.rds")
