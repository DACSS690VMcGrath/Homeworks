title = "Distribution of Cylinder Counts by Carburators and Gears",
x = "cylinders",
y = "count",
caption = "Source: mtcars data"
) +
theme_bw() +
theme(
strip.background = element_rect(fill = "gray"),
strip.text = element_text(size = 8),
panel.grid.minor = element_blank()
)
ggplot(plot_data, aes(x = factor(cyl), y = n)) +
geom_col(aes(fill = is_max),
linewidth = 0.3) +
geom_text(aes(label = pct_label),
vjust = 0.75,
size = 2.5) +
scale_fill_manual(values = c("TRUE" = "yellow", "FALSE" = "yellow"), guide = "none") +
facet_grid(gear ~ carb,
labeller = labeller(
gear = label_both,
carb = label_both
)) +
scale_y_continuous(breaks = 1:5,
limits = c(0, 5.5)) +
labs(
title = "Distribution of Cylinder Counts by Carburators and Gears",
x = "cylinders",
y = "count",
caption = "Source: mtcars data"
) +
theme_bw() +
theme(
strip.background = element_rect(fill = "gray"),
panel.grid.minor = element_blank()
)
